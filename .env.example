# Application secrets
BETTER_AUTH_SECRET=change-me
PAPERCLIP_AGENT_JWT_SECRET=change-me

# Database
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=change-me
POSTGRES_DB=paperclip
POSTGRES_PORT=54329
DATABASE_URL=postgresql://paperclip:change-me@postgres:5432/paperclip

# Runtime
NODE_ENV=production
PAPERCLIP_PORT=3100
PAPERCLIP_HOME=/home/node/paperclip
PAPERCLIP_DATA_DIR=/home/node/paperclip
PAPERCLIP_WORKSPACE_DIR=/workspace
PAPERCLIP_INSTANCE_ID=default

# Budget guardrails
PAPERCLIP_COMPANY_BUDGET_CENTS=5000
PAPERCLIP_LEAD_AGENT_BUDGET_CENTS=700
PAPERCLIP_EXEC_AGENT_BUDGET_CENTS=300
PAPERCLIP_BUDGET_WARN_PERCENT=70
PAPERCLIP_BUDGET_HARD_STOP_ENABLED=true
